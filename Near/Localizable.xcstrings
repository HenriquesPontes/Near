    "POV camera capable of recording 720p/1080p video and photos directly to local storage." : {
      "comment" : "A description of the Samsung Glasses camera system.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كاميرا POV قادرة على تسجيل فيديو وصور بدقة 720p/1080p مباشرة على وحدة التخزين المحلية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "POV-Kamera, die 720p/1080p-Videos und Fotos direkt im lokalen Speicher aufzeichnen kann."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cámara POV capaz de grabar vídeos y fotos de 720p/1080p directamente en el almacenamiento local."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caméra POV capable d'enregistrer des vidéos et des photos 720p/1080p directement sur le stockage local."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "POV कैमरा 720p/1080p वीडियो और फोटो को सीधे स्थानीय स्टोरेज में रिकॉर्ड करने में सक्षम है।"
