    "Near uses Bluetooth to estimate proximity. It requires permission to scan for devices. False positives are possible." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم Near البلوتوث لتقدير القرب. يتطلب إذنًا للبحث عن الأجهزة. الإيجابيات الكاذبة ممكنة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near nutzt Bluetooth, um die Nähe zu schätzen. Zum Scannen nach Geräten ist eine Berechtigung erforderlich. Falsch positive Ergebnisse sind möglich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near uses Bluetooth to estimate proximity. It requires permission to scan for devices. False positives are possible."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near utiliza Bluetooth para estimar la proximidad. Requiere permiso para buscar dispositivos. Los falsos positivos son posibles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near utilise Bluetooth pour estimer la proximité. Il nécessite une autorisation pour rechercher des appareils. Des faux positifs sont possibles."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near निकटता का अनुमान लगाने के लिए ब्लूटूथ का उपयोग करता है। इसके लिए उपकरणों को स्कैन करने की अनुमति की आवश्यकता होती है। गलत सकारात्मक बातें संभव हैं."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near utilizza il Bluetooth per stimare la vicinanza. Richiede l'autorizzazione per eseguire la scansione dei dispositivi. Sono possibili falsi positivi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near は Bluetooth を使用して近接性を推定します。デバイスをスキャンするには許可が必要です。誤検知の可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near은 블루투스를 사용하여 근접성을 추정합니다. 장치를 검색하려면 권한이 필요합니다. 거짓 긍정이 가능합니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PertoGlasses usa Bluetooth para estimar a proximidade. Requer permissão para procurar dispositivos. Falsos positivos são possíveis."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near usa Bluetooth para estimar a proximidade. Requer permissão para procurar dispositivos. Falsos positivos são possíveis."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near использует Bluetooth для оценки близости. Требуется разрешение на сканирование устройств. Возможны ложные срабатывания."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near 使用蓝牙来估计接近度。它需要扫描设备的权限。误报是可能的。"
          }
        }
      }
    },
