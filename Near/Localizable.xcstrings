    "Politely ask the wearer to cover the camera or remove their glasses if in a private space where recording is prohibited." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitten Sie den Träger höflich, die Kamera abzudecken oder die Brille abzunehmen, wenn Sie sich in einem privaten Raum befinden, in dem Aufnahmen verboten sind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pide educadamente al usuario que cubra la cámara o se quite las gafas si estás en un espacio privado donde la grabación está prohibida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Demandez poliment au porteur de couvrir la caméra ou de retirer ses lunettes si vous êtes dans un espace privé où l'enregistrement est interdit."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiedi gentilmente a chi li indossa di coprire la fotocamera o togliere gli occhiali se ti trovi in uno spazio privato in cui la registrazione è vietata."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peça educadamente para o usuário cobrir a câmera o retirar os óculos se estiver em um espaço privato onde a gravação é proibida."
