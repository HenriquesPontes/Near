    "Near doesn't collect your data. Everything happens entirely on your device." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near لا يجمع بياناتك. كل شيء يحدث بالكامل على جهازك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near erfasst Ihre Daten nicht. Alles geschieht vollständig auf Ihrem Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near doesn't collect your data. Everything happens entirely on your device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near no recopila sus datos. Todo sucede completamente en tu dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near ne collecte pas vos données. Tout se passe entièrement sur votre appareil."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near आपका डेटा एकत्र नहीं करता है. सब कुछ पूरी तरह से आपके डिवाइस पर होता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near non raccoglie i tuoi dati. Tutto avviene interamente sul tuo dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near はデータを収集しません。すべては完全にデバイス上で行われます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near는 데이터를 수집하지 않습니다. 모든 일은 전적으로 귀하의 장치에서 이루어집니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PertoGlasses não coleta seus dados. Tudo acontece inteiramente no seu dispositivo."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
