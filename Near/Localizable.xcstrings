    "Background App Refresh is disabled. Radar Mode cannot run in the background. Tap to open Settings." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hintergrundaktualisierung ist deaktiviert. Der Radar-Modus kann nicht im Hintergrund ausgeführt werden. Tippen Sie hier, um die Einstellungen zu öffnen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La actualización en segundo plano está desactivada. El modo Radar no puede ejecutarse en segundo plano. Toque para abrir Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'actualisation en arrière-plan est désactivée. Le mode Radar ne peut pas s'exécuter en arrière-plan. Appuyez pour ouvrir les Réglages."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'aggiornamento in background è disattivato. La modalità Radar non può essere eseguita in background. Tocca per aprire le Impostazioni."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Atualização em Segundo Plano está desativada. O Modo Radar não pode ser executado em segundo plano. Toque para abrir os Ajustes."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "后台 App 刷新已禁用。雷达模式无法在后台运行。轻点以打开设置。"
          }
        }
      }
    },
    "Background App Refresh is restricted on this device. Radar Mode cannot run in the background." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Hintergrundaktualisierung ist auf diesem Gerät eingeschränkt. Der Radar-Modus kann nicht im Hintergrund ausgeführt werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La actualización en segundo plano está restringida en este dispositivo. El modo Radar no puede ejecutarse en segundo plano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'actualisation en arrière-plan est restreinte sur cet appareil. Le mode Radar ne peut pas s'exécuter en arrière-plan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'aggiornamento in background è limitato su questo dispositivo. La modalità Radar non può essere eseguita in background."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Atualização em Segundo Plano está restrita neste dispositivo. O Modo Radar não pode ser executado em segundo plano."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此设备上限制了后台 App 刷新。雷达模式无法在后台运行。"
          }
        }
      }
    },
