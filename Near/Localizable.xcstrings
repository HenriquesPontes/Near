    "Near automatically scans when you leave home or enter public venues, and pauses when you arrive at your Safe Zone." : {
      "comment" : "A description of the geofence settings.",
      "isCommentAutoGenerated" : true
    },
    "Near detected %lld smart glasses nearby." : {
      "comment" : "When there is only one glasses device, but the name is not available.",
      "isCommentAutoGenerated" : true
    },
    "Near detected %lld smart glasses nearby. The closest is %@ at approximately %@ meters." : {
      "comment" : "Pluralization key: \"glass\" The argument is the string “%.1f”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Near detected %1$lld smart glasses nearby. The closest is %2$@ at approximately %3$@ meters."
          }
        }
      }
    },
    "Near detected 1 %@ approximately %@ meters away." : {
      "comment" : "Text displayed in a notification when a single nearby smart glasses is detected. The first argument is the name of the glasses, and the second argument is the estimated distance in meters. The second argument is the string “%.1f”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Near detected 1 %1$@ approximately %2$@ meters away."
          }
        }
      }
    },
    "Near is a utility designed to detect and log radio emissions from nearby smart glasses and optical wearables." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near عبارة عن أداة مساعدة مصممة لاكتشاف وتسجيل انبعاثات الراديو من النظارات الذكية والأجهزة البصرية القريبة التي يمكن ارتداؤها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near ist ein Dienstprogramm zur Erkennung und Protokollierung von Funkemissionen von in der Nähe befindlichen Datenbrillen und optischen Wearables."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near es una utilidad diseñada para detectar y registrar emisiones de radio de gafas inteligentes y dispositivos ópticos portátiles cercanos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near est un utilitaire conçu pour détecter et enregistrer les émissions radio des lunettes intelligentes et des appareils portables optiques à proximité."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near एक उपयोगिता है जिसे आस-पास के स्मार्ट ग्लास और ऑप्टिकल पहनने योग्य वस्तुओं से रेडियो उत्सर्जन का पता लगाने और लॉग करने के लिए डिज़ाइन किया गया है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near è un'utilità progettata per rilevare e registrare le emissioni radio provenienti da occhiali intelligenti e dispositivi ottici indossabili nelle vicinanze."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near は、近くのスマート グラスや光学式ウェアラブルからの電波放射を検出して記録するように設計されたユーティリティです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near는 근처의 스마트 안경 및 광학 웨어러블 장치에서 발생하는 무선 방출을 감지하고 기록하도록 설계된 유틸리티입니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near é um utilitário projetado para detectar e registrar emissões de rádio de óculos inteligentes e dispositivos vestíveis ópticos nas proximidades."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near é um utilitário projetado para detectar e registrar emissões de rádio de óculos inteligentes e dispositivos ópticos próximos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near — это утилита, предназначенная для обнаружения и регистрации радиоизлучения от находящихся поблизости умных очков и оптических носимых устройств."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Near 是一款实用程序，旨在检测和记录附近智能眼镜和光学可穿戴设备的无线电发射。"
          }
        }
      }
    },
