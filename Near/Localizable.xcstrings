    "Visually scan for the device. Look for someone wearing glasses with thicker frames or a tiny lens on the corner hinges." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فحص بصري للجهاز. ابحث عن شخص يرتدي نظارات ذات إطارات أكثر سمكًا أو عدسة صغيرة على مفصلات الزاوية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suchen Sie visuell nach dem Gerät. Achten Sie auf Personen mit dickeren Brillengestellen oder einer winzigen Linse an den Ecken."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escanea visualmente la zona. Busca a alguien que lleve gafas con monturas más gruesas o una lente diminuta en las bisagras de las esquinas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspectez visuellement les alentours. Recherchez quelqu'un portant des lunettes aux montures plus épaisses ou dotées d'une lentille minuscule sur les charnières."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "डिवाइस को दृष्टिगत रूप से स्कैन करें. किसी ऐसे व्यक्ति की तलाश करें जिसने मोटे फ्रेम वाला चश्मा या कोने पर छोटा लेंस पहना हो।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ispeziona visivamente l'area. Cerca qualcuno che indossi occhiali con montature più spesse o una minuscola lente sulle cerniere laterali."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デバイスを視覚的にスキャンします。太いフレームのメガネをかけている人、または角のヒンジに小さなレンズが付いているメガネをかけている人を探してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "장치를 시각적으로 검색합니다. 안경테가 더 두껍거나 모서리 경첩에 작은 렌즈가 달린 안경을 쓴 사람을 찾으세요."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspecione visualmente o ambiente. Procure por alguém usando óculos com armação mais grossa ou uma lente minúscula nas dobradiças laterais."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Procure visualmente o dispositivo. Procure alguém usando óculos com armação mais grossa ou lentes minúsculas nas dobradiças dos cantos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Визуально просканируйте устройство. Поищите кого-нибудь, кто носит очки в более толстой оправе или с крошечными линзами на угловых петлях."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "目视扫描设备。寻找戴镜框较厚或角铰链上镜片较小的眼镜的人。"
          }
        }
      }
    },
