    "Politely ask the wearer to cover the camera or remove their glasses if in a private space where recording is prohibited." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اطلب بأدب من مرتديها تغطية الكاميرا أو إزالة نظارته إذا كان في مكان خاص يُحظر فيه التسجيل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitten Sie den Träger höflich, die Kamera abzudecken oder die Brille abzunehmen, wenn Sie sich in einem privaten Raum befinden, in dem Aufnahmen verboten sind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pide educadamente al usuario que cubra la cámara o se quite las gafas si estás en un espacio privado donde la grabación está prohibida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Demandez poliment au porteur de couvrir la caméra ou de retirer ses lunettes si vous êtes dans un espace privé où l'enregistrement est interdit."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि निजी स्थान पर रिकॉर्डिंग निषिद्ध है तो पहनने वाले से विनम्रतापूर्वक कैमरा ढकने या अपना चश्मा हटाने के लिए कहें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiedi gentilmente a chi li indossa di coprire la fotocamera o togliere gli occhiali se ti trovi in uno spazio privato in cui la registrazione è vietata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "録音が禁止されているプラ​​イベートな空間では、着用者にカメラを覆うかメガネを外すよう丁寧に依頼してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "촬영이 금지된 개인 공간에서는 착용자에게 카메라를 가리거나 안경을 벗어달라고 정중하게 요청하세요."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peça educadamente para o usuário cobrir a câmera o retirar os óculos se estiver em um espaço privato onde a gravação é proibida."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peça educadamente ao usuário que cubra a câmera ou remova os óculos se estiver em um espaço privado onde a gravação é proibida."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вежливо попросите пользователя закрыть камеру или снять очки, если он находится в частном помещении, где запись запрещена."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果在禁止录制的私人空间，请礼貌地要求佩戴者遮盖相机或摘下眼镜。"
          }
        }
      }
    },
