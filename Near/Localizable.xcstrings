    "Automatically stops scanning after a certain duration to save battery life. Set to 'Never' (0 min) to scan continuously without stopping." : {
      "comment" : "A description of the scan timeout setting.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتوقف المسح تلقائيًا بعد مدة معينة لتوفير عمر البطارية. اضبط على \"أبدًا\" (0 دقيقة) للمسح بشكل مستمر دون توقف."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stoppt den Scanvorgang nach einer bestimmten Dauer automatisch, um den Akku zu schonen. Stellen Sie „Nie“ (0 Min.) ein, um kontinuierlich zu scannen, ohne anzuhalten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detiene automáticamente el escaneo después de una cierta duración para ahorrar batería. Establezca en 'Nunca' (0 min) para escanear continuamente sin detenerse."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrête automatiquement la numérisation après une certaine durée pour économiser la batterie. Réglez sur « Jamais » (0 min) pour numériser en continu sans arrêt."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बैटरी जीवन बचाने के लिए एक निश्चित अवधि के बाद स्कैनिंग स्वचालित रूप से बंद हो जाती है। बिना रुके लगातार स्कैन करने के लिए 'कभी नहीं' (0 मिनट) पर सेट करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Interrompe automaticamente la scansione dopo una certa durata per prolungare la durata della batteria. Impostare su \"Mai\" (0 min) per eseguire la scansione in modo continuo senza interruzioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "バッテリー寿命を節約するために、一定時間が経過するとスキャンを自動的に停止します。停止せずに継続的にスキャンするには、「なし」(0 分) に設定します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "배터리 수명을 절약하기 위해 특정 기간이 지나면 자동으로 스캔을 중지합니다. 중지하지 않고 계속 스캔하려면 '사용 안 함'(0분)으로 설정하세요."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Interrompe automaticamente a digitalização após um determinado período para economizar bateria. Defina como 'Nunca' (0 min) para digitalizar continuamente sem parar."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Interrompe automaticamente a digitalização após um determinado período para economizar bateria. Defina como 'Nunca' (0 min) para digitalizar continuamente sem parar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Автоматически прекращает сканирование по истечении определенного времени для экономии заряда батареи. Установите значение «Никогда» (0 минут) для непрерывного сканирования без остановки."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在一定时间后自动停止扫描以节省电池寿命。设置为“从不”（0 分钟）可连续扫描而不停止。"
          }
        }
      }
    },
    "Background App Refresh is disabled. Radar Mode cannot run in the background. Tap to open Settings." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم تعطيل تحديث التطبيقات في الخلفية. لا يمكن تشغيل وضع الرادار في الخلفية. انقر لفتح الإعدادات."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hintergrundaktualisierung ist deaktiviert. Der Radar-Modus kann nicht im Hintergrund ausgeführt werden. Tippen Sie hier, um die Einstellungen zu öffnen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La actualización en segundo plano está desactivada. El modo Radar no puede ejecutarse en segundo plano. Toque para abrir Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'actualisation en arrière-plan est désactivée. Le mode Radar ne peut pas s'exécuter en arrière-plan. Appuyez pour ouvrir les Réglages."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बैकग्राउंड ऐप रिफ्रेश अक्षम है. रडार मोड पृष्ठभूमि में नहीं चल सकता. सेटिंग्स खोलने के लिए टैप करें।"
          }
        },
        "it" : {
