    "Likely features a micro-projector or waveguide HUD for augmented reality." : {
      "comment" : "A description of the HUD of a Samsung device.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "من المحتمل أن يحتوي على جهاز عرض صغير أو دليل موجي HUD للواقع المعزز."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verfügt wahrscheinlich über einen Mikroprojektor oder ein Wellenleiter-HUD für Augmented Reality."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Probablemente cuente con un microproyector o HUD de guía de ondas para realidad aumentada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comporte probablement un micro-projecteur ou un HUD à guide d'ondes pour la réalité augmentée."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "संवर्धित वास्तविकता के लिए संभवतः एक माइक्रो-प्रोजेक्टर या वेवगाइड HUD की सुविधा है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Probabilmente presenta un microproiettore o un HUD a guida d'onda per la realtà aumentata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "おそらく、拡張現実用のマイクロプロジェクターまたは導波管 HUD が搭載されています。"
          }
        },
        "ko" : {
