    "Stereoscopic 3D cameras. Captures spatial videos and environment depth data continuously for digital twinning." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كاميرات ثلاثية الأبعاد مجسمة. يلتقط مقاطع الفيديو المكانية وبيانات عمق البيئة بشكل مستمر للتوأمة الرقمية."
          }
        },
        "de" : {
