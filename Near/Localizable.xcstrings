          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu dispositivo actualmente no está monitoreando las emisiones de radio BLE."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre appareil ne surveille pas les émissions radio BLE actuellement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका उपकरण वर्तमान में BLE रेडियो उत्सर्जन की निगरानी नहीं कर रहा है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
