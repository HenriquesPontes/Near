    "Weak signal detected. The device is far or shielded." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تم اكتشاف إشارة ضعيفة. الجهاز بعيد أو محمي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
